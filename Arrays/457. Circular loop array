class Solution {
public:
    int nextIndex(vector<int>& nums, int i) {
        int n = nums.size();
        return ((i + nums[i]) % n + n) % n;
    }

    bool circularArrayLoop(vector<int>& nums) {
        int n = nums.size();

        for (int i = 0; i < n; i++) {
            if (nums[i] == 0) continue;

            bool dir = nums[i] > 0;
            int slow = i, fast = i;

            while (true) {
                // move slow once
                int next_slow = nextIndex(nums, slow);

                // move fast once
                int next_fast = nextIndex(nums, fast);

                // direction check BEFORE second jump
                if ((nums[next_slow] > 0) != dir || 
                    (nums[next_fast] > 0) != dir)
                    break;

                // move fast second time
                next_fast = nextIndex(nums, next_fast);

                if ((nums[next_fast] > 0) != dir)
                    break;

                slow = next_slow;
                fast = next_fast;

                if (slow == fast) {
                    // ❌ reject single-element loop
                    if (slow == nextIndex(nums, slow))
                        break;
                    return true;
                }
            }

            // 🔥 CLEANUP (MOST IMPORTANT PART)
            int curr = i;
            while (nums[curr] != 0 && (nums[curr] > 0) == dir) {
                int next = nextIndex(nums, curr);
                nums[curr] = 0;
                curr = next;
            }
        }

        return false;
    }
};
