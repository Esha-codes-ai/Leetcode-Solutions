class Solution {
public:
    int missingNumber(vector<int>& nums) {
        int sum=0;
        int n=nums.size();
        int mis;
        for(int i=0;i<nums.length();i++)
        {
            sum+=nums[i];
        }
        mis=(nums.length()*(nums.length())/2);
    }
    return mis-sum;
}
    
};
