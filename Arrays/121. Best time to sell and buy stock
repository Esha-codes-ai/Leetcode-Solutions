class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int profit=0;
        //initially the profit is zero
        int min=prices[0];
        //n is the size of price in an array
        int n= prices.size();
        for(int i=1;i<n;i++)
        {
            if(prices[i]>min){
               int diff=prices[i]-min;
               //update the values of diff into the profit 
                profit=max(diff, profit);
            }
            else{
                //otherwise price is the min 
                min=prices[i];
            }
        } 
        // last return the profit 
        return profit;
    }
};
